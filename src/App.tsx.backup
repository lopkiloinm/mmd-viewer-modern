import { useState, useRef, type ChangeEvent } from 'react';
import * as THREE from 'three';
import { ThreeScene } from './components/ThreeScene';
import { Button } from './components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from './components/ui/card';
import { Play, Pause, Square, Upload, X } from 'lucide-react';
import type { LoadedModel } from './hooks/useModelLoader';

function App() {
  const [isPlaying, setIsPlaying] = useState(false);
  const [isPaused, setIsPaused] = useState(false);
  const [loadedModels, setLoadedModels] = useState<LoadedModel[]>([]);
  const [selectedModelId, setSelectedModelId] = useState<string | null>(null);
  const [textureFiles, setTextureFiles] = useState<File[]>([]);
  
  const fileInputRefs = useRef<{ [key: string]: HTMLInputElement | null }>({});

  const handleFileUpload = async (event: ChangeEvent<HTMLInputElement>, type: 'character' | 'stage' | 'music' | 'video' | 'camera') => {
    const files = event.target.files;
    if (!files || files.length === 0) return;

    try {
      if (type === 'character' || 'stage') {
        const fileArray = Array.from(files);
        const newModels: LoadedModel[] = [];
        
        for (const file of fileArray) {
          const model = await loadActualModel(file, type);
          newModels.push(model);
        }
        
        setLoadedModels(prev => [...prev, ...newModels]);
      } else {
        console.log(`Upload ${type} file:`, files[0].name);
      }
      
      event.target.value = '';
    } catch (error) {
      console.error('Error uploading file:', error);
    }
  };

  const handleTextureUpload = (event: ChangeEvent<HTMLInputElement>) => {
    const files = event.target.files;
    if (!files || files.length === 0) return;

    const textureFileArray = Array.from(files);
    setTextureFiles(prev => [...prev, ...textureFileArray]);
    console.log(`Loaded ${textureFileArray.length} texture files`);
    
    event.target.value = '';
  };

  const applyTexturesToSelectedModel = () => {
    if (!selectedModelId || textureFiles.length === 0) return;
    
    const model = loadedModels.find(m => m.id === selectedModelId);
    if (!model || model.type !== 'mmd') {
      console.log('Please select a PMX model to apply textures to');
      return;
    }

    // Apply textures to the selected model
    console.log(`Applying ${textureFiles.length} textures to model: ${model.name}`);
    
    // Create texture map
    const textureMap = new Map<string, string>();
    textureFiles.forEach(file => {
      const url = URL.createObjectURL(file);
      textureMap.set(file.name.toLowerCase(), url);
    });

    const textureLoader = new THREE.TextureLoader();
    
    model.mesh.traverse((child) => {
      if (child instanceof THREE.Mesh && child.material) {
        const materials = Array.isArray(child.material) ? child.material : [child.material];
        
        materials.forEach((mat, index) => {
          if (mat.name) {
            // Try to find texture by material name
            const textureName = mat.name.toLowerCase();
            if (textureMap.has(textureName)) {
              console.log(`Applying texture ${textureName} to material ${index}`);
              const texture = textureLoader.load(textureMap.get(textureName)!);
              texture.needsUpdate = true;
              mat.map = texture;
              mat.needsUpdate = true;
            }
          }
        });
      }
    });

    // Clean up texture URLs
    textureMap.forEach(url => URL.revokeObjectURL(url));
    setTextureFiles([]);
    console.log('Textures applied successfully!');
  };

  const loadActualModel = async (file: File, type: 'character' | 'stage'): Promise<LoadedModel> => {
    const extension = file.name.split('.').pop()?.toLowerCase();
    const objectURL = URL.createObjectURL(file);
    
    try {
      switch (extension) {
        case 'pmx':
        case 'pmd': {
          console.log(`Starting PMX/PMD loading for: ${file.name}`);
          return new Promise(async (resolve, reject) => {
            // Read the PMX file as ArrayBuffer first
            const fileReader = new FileReader();
            
            fileReader.onload = async (event) => {
              try {
                console.log('FileReader loaded, processing ArrayBuffer...');
                const arrayBuffer = event.target?.result as ArrayBuffer;
                console.log(`ArrayBuffer size: ${arrayBuffer.byteLength} bytes`);
                
                // Import MMDLoader
                console.log('Importing MMDLoader...');
                const { MMDLoader } = await import('three/examples/jsm/loaders/MMDLoader.js');
                console.log('MMDLoader imported successfully');
                
                // Create simple LoadingManager - textures will be handled separately
                const loadingManager = new THREE.LoadingManager();
                
                const loader = new MMDLoader(loadingManager);
                console.log('MMDLoader created, starting parse...');
                
                // Add timeout to detect hanging
                const parseTimeout = setTimeout(() => {
                  console.error('MMDLoader.parse() timed out after 30 seconds - likely hanging');
                  console.log('Creating fallback due to timeout...');
                  
                  // Create fallback
                  const geometry = new THREE.BoxGeometry(2, 2, 2);
                  const material = new THREE.MeshStandardMaterial({ 
                    color: 0xff6b6b,
                    roughness: 0.5,
                    metalness: 0.5
                  });
                  const mesh = new THREE.Mesh(geometry, material);
                  
                  const fallbackModel: LoadedModel = {
                    id: `${type}_${Date.now()}_${file.name}`,
                    name: `${file.name} (PMX timeout)`,
                    mesh,
                    type: 'mmd'
                  };
                  
                  resolve(fallbackModel);
                }, 30000);
                
                let parseCalled = false;
                
                // Parse the ArrayBuffer directly
                try {
                  loader.parse(
                    arrayBuffer,
                    (mesh) => {
                      if (parseCalled) {
                        console.warn('MMDLoader.parse() callback called twice!');
                        return;
                      }
                      parseCalled = true;
                      clearTimeout(parseTimeout);
                      
                      console.log('MMD model parsed successfully!');
                      console.log('Mesh object:', mesh);
                      console.log('Mesh type:', mesh.type);
                      console.log('Mesh children count:', mesh.children?.length || 0);
                      
                      // Process the loaded MMD model
                      let meshCount = 0;
                      mesh.traverse((child) => {
                        if (child instanceof THREE.Mesh) {
                          meshCount++;
                          console.log(`Processing mesh ${meshCount}: ${child.name || 'unnamed'}`);
                          if (child.material) {
                            console.log(`Material type: ${Array.isArray(child.material) ? 'array' : child.material.type}`);
                            if (Array.isArray(child.material)) {
                              child.material.forEach((mat, idx) => {
                                console.log(`Material ${idx}: map=${!!mat.map}, needsUpdate=${mat.needsUpdate}`);
                                if (mat.map) mat.map.needsUpdate = true;
                                mat.needsUpdate = true;
                              });
                            } else {
                              console.log(`Single material: map=${!!child.material.map}, needsUpdate=${child.material.needsUpdate}`);
                              if (child.material.map) child.material.map.needsUpdate = true;
                              child.material.needsUpdate = true;
                            }
                          } else {
                            console.log('Creating default material for mesh');
                            child.material = new THREE.MeshStandardMaterial({
                              color: 0xff6b6b,
                              roughness: 0.7,
                              metalness: 0.3
                            });
                          }
                          child.castShadow = true;
                          child.receiveShadow = true;
                        }
                      });
                      
                      console.log(`Processed ${meshCount} meshes total`);
                      
                      const model: LoadedModel = {
                        id: `${type}_${Date.now()}_${file.name}`,
                        name: file.name,
                        mesh: mesh,
                        type: 'mmd'
                      };
                      
                      console.log(`PMX model created: ${model.name}`);
                      resolve(model);
                    },
                    (progress) => {
                      console.log('MMD Loading progress:', (progress.loaded / progress.total) * 100 + '%');
                    },
                    (error) => {
                      if (parseCalled) {
                        console.warn('MMDLoader.parse() error callback called after success!');
                        return;
                      }
                      parseCalled = true;
                      clearTimeout(parseTimeout);
                      console.error('MMDLoader error:', error);
                      
                      // Fallback: create a placeholder
                      console.log('Creating fallback placeholder due to error');
                      const geometry = new THREE.BoxGeometry(2, 2, 2);
                      const material = new THREE.MeshStandardMaterial({ 
                        color: 0xff6b6b,
                        roughness: 0.5,
                        metalness: 0.5
                      });
                      const mesh = new THREE.Mesh(geometry, material);
                      
                      const fallbackModel: LoadedModel = {
                        id: `${type}_${Date.now()}_${file.name}`,
                        name: `${file.name} (PMX error)`,
                        mesh,
                        type: 'mmd'
                      };
                      
                      resolve(fallbackModel);
                    }
                  );
                  console.log('loader.parse() called successfully');
                } catch (parseError) {
                  clearTimeout(parseTimeout);
                  console.error('Exception during loader.parse():', parseError);
                  reject(parseError);
                }
              } catch (error) {
                console.error('Error in PMX loading:', error);
                reject(error);
              }
            };
            
            fileReader.onerror = () => {
              console.error('FileReader error');
              reject(new Error('Failed to read PMX file'));
            };
            
            console.log('Starting FileReader.readAsArrayBuffer...');
            fileReader.readAsArrayBuffer(file);
          });
        }
        
        case 'gltf':
        case 'glb': {
          // Dynamically import to avoid bundling issues
          const { GLTFLoader } = await import('three/examples/jsm/loaders/GLTFLoader.js');
          const loader = new GLTFLoader();
          
          return new Promise((resolve, reject) => {
            loader.load(objectURL, (gltf) => {
              URL.revokeObjectURL(objectURL);
              
              // Process the loaded model
              gltf.scene.traverse((child) => {
                if (child instanceof THREE.Mesh) {
                  // Ensure proper materials
                  if (!child.material) {
                    child.material = new THREE.MeshStandardMaterial({
                      color: 0x8888ff,
                      roughness: 0.7,
                      metalness: 0.3
                    });
                  }
                  // Enable shadows
                  child.castShadow = true;
                  child.receiveShadow = true;
                }
              });
              
              const model: LoadedModel = {
                id: `${type}_${Date.now()}_${file.name}`,
                name: file.name,
                mesh: gltf.scene,
                type: 'gltf',
                animations: gltf.animations
              };
              
              resolve(model);
            }, (progress) => {
              console.log('Loading progress:', (progress.loaded / progress.total) * 100 + '%');
            }, (error) => {
              URL.revokeObjectURL(objectURL);
              reject(error);
            });
          });
        }
        
        case 'fbx': {
          const { FBXLoader } = await import('three/examples/jsm/loaders/FBXLoader.js');
          const loader = new FBXLoader();
          
          return new Promise((resolve, reject) => {
            loader.load(objectURL, (object) => {
              URL.revokeObjectURL(objectURL);
              
              // Process the loaded model
              object.traverse((child) => {
                if (child instanceof THREE.Mesh) {
                  // Ensure proper materials
                  if (!child.material) {
                    child.material = new THREE.MeshStandardMaterial({
                      color: 0x4ecdc4,
                      roughness: 0.7,
                      metalness: 0.3
                    });
                  }
                  // Enable shadows
                  child.castShadow = true;
                  child.receiveShadow = true;
                }
              });
              
              const model: LoadedModel = {
                id: `${type}_${Date.now()}_${file.name}`,
                name: file.name,
                mesh: object,
                type: 'fbx',
                animations: object.animations
              };
              
              resolve(model);
            }, undefined, (error) => {
              URL.revokeObjectURL(objectURL);
              reject(error);
            });
          });
        }
        
        case 'obj': {
          const { OBJLoader } = await import('three/examples/jsm/loaders/OBJLoader.js');
          const loader = new OBJLoader();
          
          return new Promise((resolve, reject) => {
            loader.load(objectURL, (object) => {
              URL.revokeObjectURL(objectURL);
              
              // Apply materials to OBJ
              object.traverse((child) => {
                if (child instanceof THREE.Mesh) {
                  child.material = new THREE.MeshStandardMaterial({
                    color: 0xffd93d,
                    roughness: 0.8,
                    metalness: 0.2
                  });
                  child.castShadow = true;
                  child.receiveShadow = true;
                }
              });
              
              const model: LoadedModel = {
                id: `${type}_${Date.now()}_${file.name}`,
                name: file.name,
                mesh: object,
                type: 'obj'
              };
              
              resolve(model);
            }, undefined, (error) => {
              URL.revokeObjectURL(objectURL);
              reject(error);
            });
          });
        }
        
        default:
          throw new Error(`Unsupported format: ${extension}`);
      }
    } catch (error) {
      URL.revokeObjectURL(objectURL);
      throw error;
    }
  };

  const triggerFileInput = (type: string) => {
    const input = fileInputRefs.current[type];
    if (input) {
      input.click();
    }
  };

  const removeModel = (modelId: string) => {
    setLoadedModels(prev => prev.filter(model => model.id !== modelId));
    if (selectedModelId === modelId) {
      setSelectedModelId(null);
    }
  };

  const getModelsByType = (type: 'character' | 'stage') => {
    return loadedModels.filter(model => {
      if (type === 'character') {
        return ['mmd', 'pmx', 'pmd', 'vrm', 'fbx', 'gltf'].includes(model.type);
      } else {
        return ['obj', 'dae', 'stl', 'ply', 'wrl'].includes(model.type);
      }
    });
  };

  return (
    <div className="relative w-full h-screen bg-background overflow-hidden">
      <div className="absolute inset-0">
        <ThreeScene 
          className="w-full h-full" 
          models={loadedModels}
        />
      </div>

      <Card className="absolute top-4 left-4 w-80 bg-card/95 backdrop-blur-sm border-border max-h-[calc(100vh-2rem)] overflow-y-auto">
        <CardHeader className="pb-3">
          <CardTitle className="text-lg flex items-center gap-2">
            <span className="text-2xl">🎵</span>
            MMD Multi-Char Viewer
          </CardTitle>
          <CardDescription>
            Modern MMD PMX/VRM/FBX/GLB Viewer
          </CardDescription>
        </CardHeader>
        <CardContent className="space-y-4">
          <div>
            <h3 className="text-sm font-medium text-foreground mb-2">👥 Characters</h3>
            <div className="space-y-2">
              {getModelsByType('character').length === 0 ? (
                <p className="text-xs text-muted-foreground">No characters loaded</p>
              ) : (
                getModelsByType('character').map((model) => (
                  <div 
                    key={model.id} 
                    className={`text-xs p-2 bg-secondary rounded cursor-pointer flex items-center justify-between ${
                      selectedModelId === model.id ? 'ring-2 ring-primary' : ''
                    }`}
                    onClick={() => setSelectedModelId(model.id)}
                  >
                    <span className="truncate flex-1">{model.name}</span>
                    <Button
                      size="sm"
                      variant="ghost"
                      className="h-6 w-6 p-0 hover:bg-destructive hover:text-destructive-foreground"
                      onClick={(e) => {

default:
  throw new Error(`Unsupported format: ${extension}`);
}
} catch (error) {
  URL.revokeObjectURL(objectURL);
  throw error;
}
};
                getModelsByType('stage').map((model) => (
                  <div 
                    key={model.id} 
                    className={`text-xs p-2 bg-secondary rounded cursor-pointer flex items-center justify-between ${
                      selectedModelId === model.id ? 'ring-2 ring-primary' : ''
                    }`}
                    onClick={() => setSelectedModelId(model.id)}
                  >
                    <span className="truncate flex-1">{model.name}</span>
                    <Button
                      size="sm"
                      variant="ghost"
                      className="h-6 w-6 p-0 hover:bg-destructive hover:text-destructive-foreground"
                      onClick={(e) => {
                        e.stopPropagation();
                        removeModel(model.id);
                      }}
                    >
                      <X className="w-3 h-3" />
                    </Button>
                  </div>
                ))
              )}
              <Button
                size="sm"
                variant="outline"
                className="w-full hover:bg-accent hover:text-accent-foreground transition-colors"
                onClick={() => triggerFileInput('stage')}
              >
                <Upload className="w-3 h-3 mr-2" />
                Add Stage
              </Button>
              <input
                ref={el => fileInputRefs.current['stage'] = el}
                type="file"
                accept=".obj,.fbx,.gltf,.glb,.dae,.stl,.ply,.wrl,.vrml"
                multiple
                className="hidden"
                onChange={(e) => handleFileUpload(e, 'stage')}
              />
            </div>
          </div>
        </CardContent>
      </Card>

      <Card className="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-card/95 backdrop-blur-sm border-border">
        <CardContent className="flex items-center gap-2 p-3">
          <Button
            size="sm"
            onClick={() => setIsPlaying(true)}
            disabled={isPlaying && !isPaused}
            className="bg-green-600 hover:bg-green-700 text-white"
          >
            <Play className="w-4 h-4" />
          </Button>
          <Button
            size="sm"
            onClick={() => setIsPaused(!isPaused)}
            disabled={!isPlaying}
            variant="secondary"
            className="hover:bg-accent hover:text-accent-foreground transition-colors"
          >
            <Pause className="w-4 h-4" />
          </Button>
          <Button
            size="sm"
            onClick={() => {setIsPlaying(false); setIsPaused(false);}}
            disabled={!isPlaying}
            variant="destructive"
          >
            <Square className="w-4 h-4" />
          </Button>
          <div className="text-xs text-muted-foreground ml-2">
            {isPlaying ? (isPaused ? 'Paused' : 'Playing') : 'Stopped'}
          </div>
          <div className="text-xs text-muted-foreground ml-4">
            {loadedModels.length} model{loadedModels.length !== 1 ? 's' : ''} loaded
          </div>
        </CardContent>
      </Card>
    </div>
  );
}

export default App;
